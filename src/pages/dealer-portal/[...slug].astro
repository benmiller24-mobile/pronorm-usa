---
import '@/styles/portal.css';
import PortalApp from '@/components/portal/PortalApp';

export function getStaticPaths() {
  // Pre-render the known portal routes; the React SPA handles actual routing client-side
  return [
    { params: { slug: 'dashboard' } },
    { params: { slug: 'projects' } },
    { params: { slug: 'projects/new' } },
    { params: { slug: 'orders' } },
    { params: { slug: 'warranty' } },
    { params: { slug: 'warranty/new' } },
    { params: { slug: 'account' } },
  ];
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Dealer Portal — Pronorm USA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body style="margin: 0; padding: 0;">
    <PortalApp client:only="react" />
  </body>
</html>
