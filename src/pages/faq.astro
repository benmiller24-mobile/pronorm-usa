---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConsultationCTA from '@/components/ConsultationCTA.astro';

const faqs = [
  { q: "What is the difference between German fitted kitchens and American cabinets?", a: "American cabinets are individual boxes installed side by side. German fitted kitchens are engineered as complete systems — every element is designed to work together with sub-millimeter precision. The result is a seamless, architecturally integrated kitchen rather than an assembly of separate parts." },
  { q: "How much does a Pronorm kitchen cost?", a: "Typical Pronorm installations range from $40,000 to $150,000+ depending on kitchen size, complexity, and finish selections. Pronorm occupies the premium mid-range — offering authentic German engineering at pricing well below ultra-luxury brands like SieMatic or Poggenpohl." },
  { q: "How long does it take to get a Pronorm kitchen?", a: "After design finalization, Pronorm’s factory production lead time is typically 6–9 weeks, plus approximately 6 weeks for shipping. Including design consultation, planning, and installation, most projects take 4–5 months from first meeting to completed installation." },
  { q: "Where are Pronorm kitchens available in the US?", a: "Pronorm is available through authorized dealers across the United States, with our dealer network growing every month. Submit a dealer inquiry on our Find a Dealer page and we'll connect you with a design professional in your area." },
  { q: "Can I customize my Pronorm kitchen?", a: "Absolutely. Pronorm offers hundreds of door front options, finishes, and configurations. Every kitchen is manufactured to exact room specifications with millimeter-precise sizing." },
  { q: "What hardware does Pronorm use?", a: "Pronorm sources exclusively from Blum, Hettich, and Grass — the world's leading furniture fittings manufacturers. Soft-close is standard on every door and drawer, not an upgrade." },
  { q: "Is Pronorm environmentally responsible?", a: "Yes. Pronorm’s factory uses sustainably sourced wood materials, water-based adhesives with low VOC emissions, and energy-efficient processes powered partly by renewable energy. All products carry relevant European environmental certifications." },
  { q: "How do I become a Pronorm dealer?", a: "We partner with kitchen dealers who operate professional showrooms, employ trained designers, and serve premium clientele. Protected territories are available nationwide. Visit our Become a Dealer page to apply." },
  { q: "What product lines does Pronorm offer?", a: "Pronorm offers three main product lines. Proline128 features the innovative 128mm grid system with classic handles. Y‑line is a handleless kitchen with an integrated grip profile in stainless, bronze, or black anodized finishes. X‑line is a classic handleless kitchen with a gently curved C-shaped profile in 10 colour options. All three can be combined in a single kitchen." },
  { q: "Do Pronorm kitchens come with a warranty?", a: "Yes. Pronorm provides a manufacturer’s warranty covering defects in materials and workmanship. Specific terms are managed through your authorized dealer. Blum, Hettich, and Grass hardware also carry their own manufacturer warranties — Blum, for example, guarantees their hinges and runners for the lifetime of the kitchen." },
  { q: "Can Pronorm kitchens be combined with other rooms?", a: "Absolutely. Pronorm’s Living Spaces program extends the same German engineering into wardrobes, home offices, media units, mudrooms, and laundry rooms. The same fronts, finishes, and 128mm grid system used in your kitchen can carry throughout your home for a completely unified interior." },
  { q: "What finishes and materials are available?", a: "Pronorm offers an extensive palette including ultra-matte lacquer, high-gloss lacquer, real wood veneers, laminate, ceramic fronts, and glass fronts. The 2026 collection features over 120 front options across colours, textures, and materials — from arctic white and deep greens to natural oak and industrial concrete effects." },
  { q: "How is a Pronorm kitchen installed?", a: "Installation is handled by your authorized Pronorm dealer’s professional installation team. Because every kitchen is manufactured to exact room dimensions, installation is precise and efficient — typically completed in 2–3 days for a standard kitchen. Your dealer manages the entire process from delivery to final adjustment." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<BaseLayout title="FAQ" description="Frequently asked questions about Pronorm German fitted kitchens — pricing, lead times, availability, customization, and dealer partnerships." schema={faqSchema}>

  <section class="page-hero" style="position:relative; overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:url('/images/equipment/ergonomics-cabinet-heights.jpg');background-size:cover;background-position:center;opacity:0.08;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <span class="overline animate-in">FAQ</span>
      <h1 class="animate-in animate-in-delay-1">Frequently Asked<br/>Questions</h1>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item reveal">
            <summary>
              <h3>{faq.q}</h3>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>

      <div class="faq-cta" style="margin-top: var(--space-3xl); text-align: center;">
        <p style="color: var(--color-graphite);">Still have questions?</p>
        <a href="/contact" class="btn btn-outline" style="margin-top: 1rem;">Contact Us</a>
      </div>
    </div>
  </section>

  <ConsultationCTA />
</BaseLayout>

<style>
  .page-hero { padding: var(--space-5xl) 0 var(--space-2xl); }

  .faq-list { display: flex; flex-direction: column; }

  .faq-item { border-bottom: var(--border-light); padding: 1.5rem 0; }

  .faq-item summary {
    display: flex; justify-content: space-between; align-items: center; cursor: pointer;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary h3 {
    font-size: 1.15rem; font-weight: 400; padding-right: 1rem;
  }

  .faq-item summary svg {
    flex-shrink: 0; transition: transform var(--duration-normal) var(--ease-out);
    color: var(--color-copper);
  }

  .faq-item[open] summary svg { transform: rotate(180deg); }

  .faq-item p { margin-top: 1rem; color: var(--color-graphite); line-height: 1.7; padding-right: 2rem; }
</style>
