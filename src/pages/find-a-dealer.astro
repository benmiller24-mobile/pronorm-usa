---
import BaseLayout from '@/layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Find a Pronorm Dealer",
  "description": "Connect with an authorized Pronorm German kitchen dealer near you. Submit your information and our team will match you with a local design expert.",
};
---

<BaseLayout
  title="Find a Dealer"
  description="Connect with an authorized Pronorm German kitchen dealer near you. Submit your information and our team will match you with a local design expert."
  schema={schema}
>

  <section class="page-hero" style="position:relative; overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:url('/images/hero/hero-bright-handleless-island.jpg');background-size:cover;background-position:center;opacity:0.1;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <span class="overline animate-in">Authorized Dealers</span>
      <h1 class="animate-in animate-in-delay-1">Find a Pronorm<br/>Dealer Near You</h1>
      <p class="subtitle animate-in animate-in-delay-2" style="max-width: 55ch;">
        Just getting started? Tell us your location and we'll connect you with an authorized Pronorm dealer in your area — no commitment needed.
      </p>
      <p class="animate-in animate-in-delay-2" style="font-size:0.88rem; color:var(--color-warm-gray); margin-top:0.75rem;">
        Ready to dive in with budget and product details? <a href="/request-consultation" style="color:var(--color-copper); text-decoration:underline;">Request a full design consultation instead &rarr;</a>
      </p>
      <p class="animate-in animate-in-delay-2" style="font-size:0.88rem; color:var(--color-warm-gray); margin-top:0.5rem;">
        Or <a href="/dealers" style="color:var(--color-copper); text-decoration:underline;">browse all authorized showroom locations &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section class="section">
    <div class="container">
      <div class="inquiry-grid">

        <div class="inquiry-info reveal">
          <h2>How It Works</h2>
          <hr class="divider" style="margin: 1.5rem 0;" />

          <div class="step-list">
            <div class="step-item">
              <span class="step-num">1</span>
              <div>
                <strong>Tell Us About Your Project</strong>
                <p>Share your location, timeline, and what you're looking for in a kitchen.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">2</span>
              <div>
                <strong>We Match You With a Dealer</strong>
                <p>Our team will identify the best authorized Pronorm dealer for your area and project needs.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">3</span>
              <div>
                <strong>Your Dealer Reaches Out</strong>
                <p>Your matched dealer will contact you to schedule a complimentary design consultation.</p>
              </div>
            </div>
          </div>

          <div class="info-note" style="margin-top: var(--space-2xl);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-copper)" stroke-width="1.5" style="flex-shrink:0;margin-top:2px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <p>Pronorm dealers are located across the United States, with our network growing every month. No matter where you are, we'll work to connect you with the right design professional.</p>
          </div>
        </div>

        <form class="inquiry-form reveal" name="dealer-inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you">
          <input type="hidden" name="form-name" value="dealer-inquiry" />
          <p style="display:none;"><input name="bot-field" /></p>

          <h3>Request a Dealer Connection</h3>
          <p class="form-subtitle">We'll respond within 1–2 business days.</p>

          <div class="form-row">
            <div class="form-group">
              <label>First Name *</label>
              <input type="text" name="first-name" required />
            </div>
            <div class="form-group">
              <label>Last Name *</label>
              <input type="text" name="last-name" required />
            </div>
          </div>

          <div class="form-group">
            <label>Email *</label>
            <input type="email" name="email" required />
          </div>

          <div class="form-group">
            <label>Phone</label>
            <input type="tel" name="phone" />
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>City *</label>
              <input type="text" name="city" required />
            </div>
            <div class="form-group">
              <label>State *</label>
              <input type="text" name="state" required />
            </div>
          </div>

          <div class="form-group">
            <label>Zip Code *</label>
            <input type="text" name="zip" required />
          </div>

          <div class="form-group">
            <label>Project Type</label>
            <select name="project-type">
              <option value="">Select one...</option>
              <option value="new-construction">New Construction</option>
              <option value="full-renovation">Full Kitchen Renovation</option>
              <option value="partial-renovation">Partial Kitchen Update</option>
              <option value="living-spaces">Living Spaces Furniture</option>
              <option value="just-exploring">Just Exploring Options</option>
            </select>
          </div>

          <div class="form-group">
            <label>Estimated Timeline</label>
            <select name="timeline">
              <option value="">Select one...</option>
              <option value="0-3">Within 3 months</option>
              <option value="3-6">3–6 months</option>
              <option value="6-12">6–12 months</option>
              <option value="12+">12+ months</option>
              <option value="not-sure">Not sure yet</option>
            </select>
          </div>

          <div class="form-group">
            <label>Tell Us About Your Project</label>
            <textarea name="message" rows="4" placeholder="Anything you'd like us to know — style preferences, kitchen size, must-haves..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
            Submit Request
          </button>
        </form>

      </div>
    </div>
  </section>

  <!-- Become a Dealer CTA -->
  <section class="section bg-ivory">
    <div class="container">
      <div class="dealer-cta-box reveal" style="text-align:center; max-width: 40rem; margin: 0 auto;">
        <span class="overline">Dealer Opportunities</span>
        <h2 style="margin-top: 0.5rem;">Become a Pronorm Dealer</h2>
        <p style="margin-top: 1rem;">Are you a kitchen dealer interested in offering authentic German kitchen design? Protected territories available nationwide with dedicated US support from Pinnacle Sales.</p>
        <a href="/become-a-dealer" class="btn btn-outline" style="margin-top: 1.5rem;">
          Dealer Partnership Info
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero { padding: var(--space-5xl) 0 var(--space-2xl); }

  .inquiry-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .inquiry-info h2 { font-size: 1.6rem; }

  .step-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .step-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-num {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-copper);
    color: var(--color-white);
    font-size: 0.82rem;
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .step-item strong { display: block; font-size: 0.95rem; margin-bottom: 0.2rem; }
  .step-item p { font-size: 0.85rem; color: var(--color-graphite); }

  .info-note {
    display: flex;
    gap: 0.75rem;
    padding: 1.2rem;
    background: var(--color-ivory);
    border-left: 3px solid var(--color-copper);
  }

  .info-note p { font-size: 0.85rem; color: var(--color-graphite); }

  .inquiry-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    background: var(--color-ivory);
    padding: 2.5rem;
    border: 1px solid var(--color-sand);
  }

  .inquiry-form h3 { font-size: 1.2rem; margin-bottom: 0; }
  .form-subtitle { font-size: 0.85rem; color: var(--color-warm-gray); margin-top: -0.5rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; }

  @media (max-width: 768px) {
    .inquiry-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .inquiry-form { padding: 1.5rem; }
  }
</style>
