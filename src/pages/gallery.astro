---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConsultationCTA from '@/components/ConsultationCTA.astro';

const galleryItems = [
  { title: "Contemporary Handleless", style: "Modern", collection: "Y‑line", image: "/images/gallery/japandi-kitchen-full.webp", ar: "3/4" },
  { title: "Warm Walnut Island", style: "Organic Modern", collection: "Proline128", image: "/images/gallery/kitchen-stone-walnut-beitrag.webp", ar: "4/3" },
  { title: "Classic Elegance", style: "Transitional", collection: "X‑line", image: "/images/gallery/contemporary-traditional-twist.jpg", ar: "4/3" },
  { title: "Matte Black & Oak", style: "Modern", collection: "Y‑line", image: "/images/gallery/dark-black-boho.webp", ar: "3/4" },
  { title: "All-White European", style: "Minimalist", collection: "Y‑line", image: "/images/gallery/modern-light-kitchen.webp", ar: "4/3" },
  { title: "Textured Oak Open Plan", style: "Organic Modern", collection: "Proline128", image: "/images/gallery/dark-contemporary-open-plan.jpg", ar: "4/3" },
  { title: "High-Gloss Lacquer", style: "Modern", collection: "Y‑line", image: "/images/style-gallery/Y_LH_Glanzweiss_01-BEITRAG.jpg", ar: "3/4" },
  { title: "Soft Curve Handleless", style: "Transitional", collection: "X‑line", image: "/images/gallery/light-curved-kitchen-beitrag.webp", ar: "4/3" },
  { title: "Japan-Inspired Minimalism", style: "Minimalist", collection: "Y‑line", image: "/images/gallery/japandi-kitchen-island.webp", ar: "4/3" },
  { title: "Mountain Modern", style: "Modern", collection: "X‑line", image: "/images/gallery/dark-contemporary-statement.jpg", ar: "3/4" },
  { title: "Desert Contemporary", style: "Organic Modern", collection: "Proline128", image: "/images/gallery/boho-oak-handleless-white.webp", ar: "4/3" },
  { title: "Urban Penthouse", style: "Modern", collection: "Y‑line", image: "/images/gallery/striking-monochrome.jpg", ar: "4/3" },
  { title: "Copper & Bronze Statement", style: "Modern", collection: "Y‑line", image: "/images/style-gallery/ME_Effektlack-Kupfer_Y-VU_Alba-Eiche-schwarz-BEITRAG.jpg", ar: "4/3" },
  { title: "Midnight Blue & Stone", style: "Transitional", collection: "X‑line", image: "/images/gallery/midnight-blue-light-grey.jpg", ar: "3/4" },
  { title: "Sherwood Dark Open Concept", style: "Organic Modern", collection: "Y‑line", image: "/images/gallery/dark-sherwood-super-white.jpg", ar: "4/3" },
  { title: "Sand Tones & Oak", style: "Minimalist", collection: "Y‑line", image: "/images/style-gallery/Y_LM_Mattlack-sand_ER_Alteiche-natur-BEITRAG.jpg", ar: "4/3" },
  { title: "Burgundy Handleless", style: "Modern", collection: "Y‑line", image: "/images/gallery/modern-handleless-burgundy.webp", ar: "3/4" },
  { title: "Organic Platinum & Oak", style: "Organic Modern", collection: "X‑line", image: "/images/style-gallery/X_OS_organic-platin_EE_Asteiche-schwarz-BEITRAG.jpg", ar: "4/3" },
  { title: "Deep Green Matte Lacquer", style: "Modern", collection: "Y‑line", image: "/images/style-gallery/Y_LM_Mattlack_dunkelgruen_LM_Mattlack_graugruen_featured.jpg", ar: "3/4" },
  { title: "Gold Metal & Dark Steel", style: "Modern", collection: "Y‑line", image: "/images/style-gallery/MM_Metall-gold_MP_Stahl-dunkel-ultramatt-BEITRAG.jpg", ar: "4/3" },
  { title: "Country House Frame Front", style: "Transitional", collection: "Proline128", image: "/images/style-gallery/pronorm-kitchen-country-house-frame-front-mediterranean-grey-Beitragsbild.jpg", ar: "4/3" },
  { title: "Jade Green & Angora Oak", style: "Organic Modern", collection: "Proline128", image: "/images/style-gallery/TU-Jadegruen-EI-Eiche-Angora-grau.-beitragsbild-1.jpg", ar: "4/3" },
  { title: "Living Wall Showcase", style: "Modern", collection: "Y‑line", image: "/images/gallery/living-wall-showcase.webp", ar: "3/4" },
  { title: "Boho Oak Handleless", style: "Organic Modern", collection: "Y‑line", image: "/images/style-gallery/pronorm-boho-oak-kitchen-handleless-white-Beitrag.webp", ar: "4/3" },
  { title: "Ice Blue Handleless", style: "Minimalist", collection: "X‑line", image: "/images/style-gallery/X_TU_eisblau_TU_eisblau-BEITRAG.jpg", ar: "4/3" },
  { title: "Champagne Organic Glass", style: "Modern", collection: "X‑line", image: "/images/style-gallery/X_OS_organic-champagner_OS_organic-champagner_GE_Messing-gebuerstet-BEITRAG.jpg", ar: "3/4" },
  { title: "Dark Designer Kitchen", style: "Modern", collection: "Y‑line", image: "/images/style-gallery/pronorm-dark-designer-kitchen-beitrag.webp", ar: "4/3" },
  { title: "Warm Kitchen Aesthetics", style: "Organic Modern", collection: "Proline128", image: "/images/style-gallery/pronorm-warm-kitchen-aesthetics-modern-minimalistic-high-quality_BEITRAGsbild.jpg", ar: "4/3" },
];

const styles = [...new Set(galleryItems.map(g => g.style))];
---

<BaseLayout
  title="Design Gallery"
  description="Browse real Pronorm German kitchen installations across the United States — Y‑line, X‑line, and Proline128 designs in American homes from coast to coast."
>

<section class="page-hero" style="position:relative; overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:url('/images/hero/hero-boho-handleless-bright.webp');background-size:cover;background-position:center;opacity:0.12;"></div>
  <div class="container" style="position:relative;z-index:1;">
    <span class="overline animate-in">Gallery</span>
    <h1 class="animate-in animate-in-delay-1">Kitchen<br/>Inspiration</h1>
    <p class="subtitle animate-in animate-in-delay-2" style="max-width: 55ch;">
      Real Pronorm kitchens in American homes — each one a collaboration between homeowner, dealer, and German craftsmanship.
    </p>
  </div>
</section>

<section class="filter-bar">
  <div class="container">
    <div class="filters">
      <button class="filter-btn active" data-filter="all">All Projects</button>
      {styles.map(s => <button class="filter-btn" data-filter={s}>{s}</button>)}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-wide">
    <div class="gallery-grid">
      {galleryItems.map((item, i) => (
        <div class="gallery-card reveal" data-style={item.style} data-collection={item.collection}>
          <div style={`aspect-ratio: ${item.ar}; overflow:hidden; border-radius: 4px;`}>
            <img src={item.image} alt={item.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform .6s;" />
          </div>
          <div class="gallery-card-info">
            <h4>{item.title}</h4>
            <span class="gallery-meta">{item.collection} · {item.style}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section bg-ivory text-center">
  <div class="container-narrow">
    <span class="overline">Share Your Pronorm</span>
    <h2 style="margin-top: 0.5rem;">Tag @pronormusa on Instagram</h2>
    <p class="subtitle" style="margin: 1rem auto 0; max-width: 50ch;">
      Love your Pronorm kitchen? Share your project with our community. Tag us for a chance to be featured in our gallery.
    </p>
    <a href="https://www.instagram.com/pronormusa" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top: 1.5rem;">Follow @pronormusa</a>
  </div>
</section>

<ConsultationCTA />
</BaseLayout>

<style>
.page-hero {
  padding: var(--space-5xl) 0 var(--space-2xl);
}
.filter-bar {
  padding: var(--space-lg) 0;
  border-bottom: var(--border-light);
  position: sticky;
  top: 64px;
  background: rgba(253,252,250,.95);
  backdrop-filter: blur(10px);
  z-index: 100;
}
.filters {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.filter-btn {
  font-family: var(--font-body);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.5rem 1.2rem;
  border: 1.5px solid var(--color-sand);
  background: transparent;
  color: var(--color-graphite);
  cursor: pointer;
  transition: all var(--duration-fast) ease;
}
.filter-btn:hover,
.filter-btn.active {
  background: var(--color-black);
  border-color: var(--color-black);
  color: var(--color-white);
}
.gallery-grid {
  columns: 3;
  column-gap: var(--space-lg);
}
.gallery-card {
  break-inside: avoid;
  margin-bottom: var(--space-lg);
  overflow: hidden;
  cursor: pointer;
}
.gallery-card:hover img {
  transform: scale(1.03);
}
.gallery-card-info {
  padding: 1rem 0;
}
.gallery-card-info h4 {
  font-size: 1rem;
  line-height: 1.3;
}
.gallery-meta {
  font-size: 0.78rem;
  color: var(--color-warm-gray);
  margin-top: 0.2rem;
  display: block;
}
@media (max-width: 1024px) {
  .gallery-grid { columns: 2; }
}
@media (max-width: 768px) {
  .gallery-grid { columns: 1; }
}
</style>
