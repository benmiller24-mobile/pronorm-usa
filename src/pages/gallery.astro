---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConsultationCTA from '@/components/ConsultationCTA.astro';
import { galleryItems } from '@/data/gallery';

const styles = [...new Set(galleryItems.map(g => g.style))];

const featuredVideos = [
  { title: "Kitchen Product Spot — Modern Handleless", src: "/videos/kitchen-spot-1.mp4", poster: "/images/gallery/kitchen-spot-1-poster.jpg" },
  { title: "Kitchen Product Spot — Contemporary Living", src: "/videos/kitchen-spot-4.mp4", poster: "/images/gallery/kitchen-spot-4-poster.jpg" },
];
---

<BaseLayout
  title="Design Gallery"
  description="Browse real Pronorm German kitchen installations across the United States — Y‑line, X‑line, and Proline128 designs in American homes from coast to coast."
>

<section class="page-hero" style="position:relative; overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:url('/images/hero/hero-boho-handleless-bright.webp');background-size:cover;background-position:center;opacity:0.12;"></div>
  <div class="container" style="position:relative;z-index:1;">
    <span class="overline animate-in">Gallery</span>
    <h1 class="animate-in animate-in-delay-1">Kitchen<br/>Inspiration</h1>
    <p class="subtitle animate-in animate-in-delay-2" style="max-width: 55ch;">
      Real Pronorm kitchens in American homes — each one a collaboration between homeowner, dealer, and German craftsmanship.
    </p>
  </div>
</section>

<!-- Featured Videos -->
<section class="section video-section">
  <div class="container">
    <span class="overline">Featured</span>
    <h2 style="margin-top: 0.5rem;">Product Films</h2>
    <p class="subtitle" style="max-width: 55ch; margin: 0.75rem 0 2rem;">
      Experience Pronorm craftsmanship in motion — cinematic glimpses of our kitchen collections.
    </p>
    <div class="video-grid">
      {featuredVideos.map(v => (
        <div class="video-card reveal">
          <div class="video-wrapper">
            <video
              controls
              preload="metadata"
              poster={v.poster}
              playsinline
            >
              <source src={v.src} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
          <div class="video-info">
            <h4>{v.title}</h4>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="filter-bar">
  <div class="container">
    <div class="filters">
      <button class="filter-btn active" data-filter="all">All Projects</button>
      {styles.map(s => <button class="filter-btn" data-filter={s}>{s}</button>)}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-wide">
    <div class="gallery-grid">
      {galleryItems.map((item, i) => (
        <a href={`/gallery/${item.slug}`} class="gallery-card reveal" data-style={item.style} data-collection={item.collection}>
          <div style={`aspect-ratio: ${item.ar}; overflow:hidden; border-radius: 4px;`}>
            <img src={item.image} alt={item.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform .6s;" />
          </div>
          <div class="gallery-card-info">
            <h4>{item.title}</h4>
            <span class="gallery-meta">{item.collection} · {item.style}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section bg-ivory text-center">
  <div class="container-narrow">
    <span class="overline">Share Your Pronorm</span>
    <h2 style="margin-top: 0.5rem;">Tag @pronormusa on Instagram</h2>
    <p class="subtitle" style="margin: 1rem auto 0; max-width: 50ch;">
      Love your Pronorm kitchen? Share your project with our community. Tag us for a chance to be featured in our gallery.
    </p>
    <a href="https://www.instagram.com/pronormusa" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top: 1.5rem;">Follow @pronormusa</a>
  </div>
</section>

<ConsultationCTA />
</BaseLayout>

<style>
.page-hero {
  padding: var(--space-5xl) 0 var(--space-2xl);
}
/* Video Section */
.video-section {
  padding-bottom: 0;
}
.video-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-xl);
}
.video-card {
  border-radius: 8px;
  overflow: hidden;
}
.video-wrapper {
  position: relative;
  aspect-ratio: 16/9;
  background: #1a1a1a;
  border-radius: 8px;
  overflow: hidden;
}
.video-wrapper video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.video-info {
  padding: 1rem 0;
}
.video-info h4 {
  font-size: 1rem;
  line-height: 1.3;
  margin: 0;
}
@media (max-width: 768px) {
  .video-grid { grid-template-columns: 1fr; }
}
/* Filter Bar */
.filter-bar {
  padding: var(--space-lg) 0;
  border-bottom: var(--border-light);
  position: sticky;
  top: 64px;
  background: rgba(253,252,250,.95);
  backdrop-filter: blur(10px);
  z-index: 100;
}
.filters {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.filter-btn {
  font-family: var(--font-body);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.5rem 1.2rem;
  border: 1.5px solid var(--color-sand);
  background: transparent;
  color: var(--color-graphite);
  cursor: pointer;
  transition: all var(--duration-fast) ease;
}
.filter-btn:hover,
.filter-btn.active {
  background: var(--color-black);
  border-color: var(--color-black);
  color: var(--color-white);
}
.gallery-grid {
  columns: 3;
  column-gap: var(--space-lg);
}
.gallery-card {
  break-inside: avoid;
  margin-bottom: var(--space-lg);
  overflow: hidden;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
  display: block;
}
.gallery-card:hover img {
  transform: scale(1.03);
}
.gallery-card-info {
  padding: 1rem 0;
}
.gallery-card-info h4 {
  font-size: 1rem;
  line-height: 1.3;
}
.gallery-meta {
  font-size: 0.78rem;
  color: var(--color-warm-gray);
  margin-top: 0.2rem;
  display: block;
}
@media (max-width: 1024px) {
  .gallery-grid { columns: 2; }
}
@media (max-width: 768px) {
  .gallery-grid { columns: 1; }
}
</style>
