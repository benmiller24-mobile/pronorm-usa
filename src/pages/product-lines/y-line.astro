---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConsultationCTA from '@/components/ConsultationCTA.astro';
---

<BaseLayout
  title="Y‑line — The Unique Handleless Kitchen"
  description="Pronorm Y‑line: the unique handleless kitchen with integrated grip profile in stainless, bronze, or black anodized finishes. Contemporary living through handleless elegance and clean, linear design."
>
  <section class="collection-hero">
    <div class="hero-bg img-placeholder-dark" style="aspect-ratio: unset; position: absolute; inset: 0;"><span>Y‑line Handleless Kitchen</span></div>
    <div style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(26,26,26,0.8) 0%, rgba(26,26,26,0.2) 70%); z-index: 2;"></div>
    <div style="position: relative; z-index: 3;" class="container">
      <span class="overline animate-in" style="color: var(--color-copper);">Product Line</span>
      <h1 class="animate-in animate-in-delay-1" style="color: var(--color-white);">Y‑line</h1>
      <p class="animate-in animate-in-delay-2" style="color: var(--color-sand); font-family: var(--font-display); font-size: 1.3rem; font-style: italic; max-width: 50ch; margin-top: 0.75rem;">The unique handleless kitchen. Contemporary living through a captivating fusion of handleless elegance and clean, linear design.</p>
    </div>
  </section>

  <!-- Design Philosophy -->
  <section class="section-lg">
    <div class="container">
      <div class="detail-grid">
        <div class="reveal">
          <span class="overline">Design Philosophy</span>
          <h2 style="margin-top: 0.5rem;">Form, Function<br/>& Ergonomics</h2>
          <hr class="divider" style="margin: 1.5rem 0;" />
          <p>Y‑line brings a captivating identity to modern living. A concept for design-forward interiors that masterfully balance form, function, and ergonomics. The integrated grip profile is not only visually striking but provides an exceptionally comfortable user experience.</p>
          <p style="margin-top: 1rem;">The rear handle rail behind the grip profile can be supplied in the front's colour or in a contrasting shade of your choice — allowing for fully personalized kitchen designs. Every detail is considered to transform your home into a unique expression of your personality.</p>
        </div>
        <div class="reveal">
          <div class="img-placeholder" style="aspect-ratio: 3/4;"><span>Y‑line Grip Profile Detail</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Grip Profile Options -->
  <section class="section bg-ivory">
    <div class="container text-center">
      <span class="overline">Integrated Grip Profile</span>
      <h2 style="margin-top: 0.5rem;">Three Finishes, Endless Possibilities</h2>
      <p class="subtitle" style="margin: 1rem auto 2rem; max-width: 55ch;">The Y‑line grip profile is available in three premium anodized finishes — each transforming the kitchen's character while maintaining seamless handleless operation.</p>
      <div class="finish-grid">
        <div class="finish-card reveal">
          <div class="img-placeholder-square img-placeholder"><span>Stainless Finish</span></div>
          <h4 style="margin-top: 0.75rem;">Stainless</h4>
          <p style="font-size: 0.85rem; color: var(--color-warm-gray);">Clean, contemporary brightness</p>
        </div>
        <div class="finish-card reveal">
          <div class="img-placeholder-square img-placeholder"><span>Bronze Finish</span></div>
          <h4 style="margin-top: 0.75rem;">Bronze</h4>
          <p style="font-size: 0.85rem; color: var(--color-warm-gray);">Warm, organic elegance</p>
        </div>
        <div class="finish-card reveal">
          <div class="img-placeholder-square img-placeholder"><span>Black Anodized Finish</span></div>
          <h4 style="margin-top: 0.75rem;">Black Anodized</h4>
          <p style="font-size: 0.85rem; color: var(--color-warm-gray);">Bold, architectural contrast</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Y-line Plus -->
  <section class="section">
    <div class="container">
      <div class="detail-grid reverse">
        <div class="reveal">
          <div class="img-placeholder" style="aspect-ratio: 4/3;"><span>Y‑line Plus — Customized Ergonomics</span></div>
        </div>
        <div class="reveal">
          <span class="overline">Enhanced Ergonomics</span>
          <h2 style="margin-top: 0.5rem;">Y‑line Plus</h2>
          <hr class="divider" style="margin: 1.5rem 0;" />
          <p>Y‑line plus goes beyond the standard, offering maximum, tailored ergonomics — whether for taller individuals or to achieve a more striking design with a lower plinth.</p>
          <p style="margin-top: 1rem;">Custom plinth heights, adjusted working heights, and personalized proportions ensure your kitchen isn't just beautiful — it's built specifically for how you live and cook.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Rear Handle Rail -->
  <section class="section bg-cream">
    <div class="container text-center">
      <span class="overline">Personalization</span>
      <h2 style="margin-top: 0.5rem;">Rear Handle Rail</h2>
      <p class="subtitle" style="margin: 1rem auto 0; max-width: 55ch;">The rear handle rail behind the grip profile can match your front colour for a seamless look — or contrast it for a striking design statement. Your choice transforms the entire character of the kitchen.</p>
      <div class="rail-demo" style="margin-top: 2.5rem;">
        <div class="img-placeholder" style="aspect-ratio: 21/9; max-width: 1000px; margin: 0 auto;"><span>Rear Handle Rail — Matching vs Contrasting Colour</span></div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="container text-center">
      <span class="overline">Gallery</span>
      <h2 style="margin-top: 0.5rem;">Y‑line in American Homes</h2>
      <div class="project-grid" style="margin-top: var(--space-2xl);">
        <div class="img-placeholder reveal" style="aspect-ratio: 16/10;"><span>Y‑line — Coastal Modern</span></div>
        <div class="img-placeholder reveal" style="aspect-ratio: 1;"><span>Y‑line — Bronze Profile Detail</span></div>
        <div class="img-placeholder reveal" style="aspect-ratio: 1;"><span>Y‑line — Island Design</span></div>
        <div class="img-placeholder reveal" style="aspect-ratio: 1;"><span>Y‑line — Tall Units</span></div>
        <div class="img-placeholder reveal" style="aspect-ratio: 1;"><span>Y‑line — Open Plan</span></div>
        <div class="img-placeholder reveal" style="aspect-ratio: 16/10;"><span>Y‑line — Full Kitchen View</span></div>
      </div>
    </div>
  </section>

  <ConsultationCTA heading="Experience Y‑line In Person" text="Visit an authorized Pronorm dealer to see the integrated grip profile in stainless, bronze, and black anodized finishes." />
</BaseLayout>

<style>
  .collection-hero { position: relative; min-height: 65vh; display: flex; align-items: center; overflow: hidden; }
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4xl); align-items: center; }
  .detail-grid.reverse > :first-child { order: 1; }
  .detail-grid.reverse > :last-child { order: 2; }
  .finish-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-xl); }
  .project-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
  .project-grid .img-placeholder { transition: transform 0.8s cubic-bezier(0.16,1,0.3,1); cursor: pointer; }
  .project-grid .img-placeholder:hover { transform: scale(1.03); }

  @media (max-width: 768px) {
    .detail-grid, .project-grid { grid-template-columns: 1fr; }
    .detail-grid.reverse > :first-child { order: 2; }
    .detail-grid.reverse > :last-child { order: 1; }
    .finish-grid { grid-template-columns: 1fr; }
  }
</style>
