---
import BaseLayout from '@/layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Request a Pronorm Kitchen Consultation",
  "description": "Schedule a complimentary design consultation with an authorized Pronorm German kitchen dealer."
};
---

<BaseLayout
  title="Request a Consultation"
  description="Schedule a complimentary Pronorm German kitchen design consultation. Our authorized dealers provide expert 3D planning, material selection, and project management."
  schema={schema}
>

  <section class="consult-page section-lg" style="position:relative;">
    <div style="position:absolute;inset:0;background-image:url('/images/gallery/japandi-kitchen-full.webp');background-size:cover;background-position:center;opacity:0.05;pointer-events:none;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="consult-grid">
        <div class="consult-content animate-in">
          <span class="overline">Complimentary Consultation</span>
          <h1 style="margin-top: 0.5rem; font-size: clamp(2.2rem, 4vw, 3.2rem);">Let's Design Your<br/>Dream Kitchen</h1>
          <hr class="divider" style="margin: 1.5rem 0;" />
          <p>Ready to start planning your dream kitchen? Share your budget, style preferences, and product interests below. An authorized Pronorm dealer will reach out within 48 hours to schedule your complimentary design consultation.</p>
          <p style="font-size:0.88rem; color:var(--color-warm-gray); margin-top:0.75rem;">
            Not ready for a full consultation? <a href="/find-a-dealer" style="color:var(--color-copper); text-decoration:underline;">Just find a dealer near you &rarr;</a>
          </p>

          <div class="consult-includes" style="margin-top: 2rem;">
            <h4 style="font-size: 0.95rem; font-family: var(--font-body); font-weight: 600;">Your consultation includes:</h4>
            <div class="includes-list">
              <div class="include-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-copper)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>In-depth design discussion</span>
              </div>
              <div class="include-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-copper)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Material and finish selection</span>
              </div>
              <div class="include-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-copper)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>3D photorealistic kitchen plan</span>
              </div>
              <div class="include-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-copper)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Budgetary pricing estimate</span>
              </div>
              <div class="include-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-copper)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Timeline and process overview</span>
              </div>
            </div>
          </div>

          <div class="consult-quote" style="margin-top: 2.5rem;">
            <blockquote>"The difference between an American cabinet showroom and a Pronorm consultation is night and day. It's a design experience, not a sales pitch."</blockquote>
            <cite>— Pronorm Homeowner, Scottsdale AZ</cite>
          </div>
        </div>

        <div class="consult-form-wrap animate-in animate-in-delay-2">
          <form class="consult-form" name="consultation" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you">
            <input type="hidden" name="form-name" value="consultation" />
            <p style="display:none;"><input name="bot-field" /></p>

            <div class="form-row">
              <div class="form-group">
                <label for="first-name">First Name *</label>
                <input type="text" id="first-name" name="first-name" required />
              </div>
              <div class="form-group">
                <label for="last-name">Last Name *</label>
                <input type="text" id="last-name" name="last-name" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="city">City *</label>
                <input type="text" id="city" name="city" required />
              </div>
              <div class="form-group">
                <label for="state">State *</label>
                <select id="state" name="state" required>
                  <option value="">Select...</option>
                  <option>Arizona</option><option>California</option><option>Colorado</option>
                  <option>Idaho</option><option>Montana</option><option>Nevada</option>
                  <option>Oregon</option><option>Utah</option><option>Washington</option>
                  <option>Wyoming</option><option>Other</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="project-type">Project Type</label>
              <select id="project-type" name="project-type">
                <option value="">Select...</option>
                <option>New Construction</option>
                <option>Full Kitchen Remodel</option>
                <option>Partial Kitchen Update</option>
                <option>Just Exploring / Early Planning</option>
              </select>
            </div>

            <div class="form-group">
              <label for="budget">Approximate Budget</label>
              <select id="budget" name="budget">
                <option value="">Prefer not to say</option>
                <option>$40,000 – $75,000</option>
                <option>$75,000 – $100,000</option>
                <option>$100,000 – $150,000</option>
                <option>$150,000+</option>
              </select>
            </div>

            <div class="form-group">
              <label for="product-lines">Product Lines of Interest</label>
              <div class="checkbox-group">
                <label class="checkbox-label"><input type="checkbox" name="product-lines" value="Y-line" /> Y‑line Handleless</label>
                <label class="checkbox-label"><input type="checkbox" name="product-lines" value="X-line" /> X‑line Classic Handleless</label>
                <label class="checkbox-label"><input type="checkbox" name="product-lines" value="Proline128" /> Proline128 with Handles</label>
                <label class="checkbox-label"><input type="checkbox" name="product-lines" value="Not sure" /> Not sure yet</label>
              </div>
            </div>

            <div class="form-group">
              <label for="message">Tell Us About Your Project</label>
              <textarea id="message" name="message" rows="4" placeholder="Describe your vision, timeline, or any questions you have..."></textarea>
            </div>

            <div class="form-group">
              <label for="referral">How Did You Hear About Pronorm?</label>
              <select id="referral" name="referral">
                <option value="">Select...</option>
                <option>Instagram</option><option>Pinterest</option><option>Google Search</option>
                <option>Houzz</option><option>Interior Designer Referral</option>
                <option>Builder Referral</option><option>Friend / Family</option>
                <option>Magazine / Publication</option><option>Other</option>
              </select>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 0.5rem;">
              Submit Consultation Request
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>

            <p class="form-note">We respect your privacy. Your information is shared only with your nearest authorized Pronorm dealer.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .consult-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-4xl);
    align-items: flex-start;
  }

  .includes-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.75rem;
  }

  .include-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--color-graphite);
  }

  .consult-quote blockquote {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-graphite);
    border-left: 2px solid var(--color-copper);
    padding-left: 1.5rem;
    line-height: 1.5;
  }

  .consult-quote cite {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.82rem;
    color: var(--color-warm-gray);
    font-style: normal;
    padding-left: 1.5rem;
  }

  .consult-form-wrap {
    background: var(--color-ivory);
    padding: 2.5rem;
    border: 1px solid var(--color-sand);
  }

  .consult-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.3rem;
  }

  .checkbox-label {
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-graphite);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
  }

  .checkbox-label input { width: auto; }

  .form-note {
    font-size: 0.78rem;
    color: var(--color-warm-gray);
    text-align: center;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .consult-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .consult-form-wrap { padding: 1.5rem; }
  }
</style>
